---
import "../styles/global.css";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

const {
  title = "BoredOS",
  description = "A modern x86_64 hobbyist operating system built from the ground up.",
  image = "/branding/bOS14.png"
} = Astro.props;

const pageTitle = title ? `${title} - BoredOS` : "BoredOS";
const baseUrl = import.meta.env.BASE_URL || "/";
const iconHref = `${baseUrl}branding/bOS14.png`;
const ogImage = image.startsWith("http") ? image : `${baseUrl}${image.replace(/^\//, "")}`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="icon" href={iconHref} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <div class="page">
      <SiteHeader />
      <main>
        <slot />
      </main>
      <SiteFooter />
    </div>
  </body>
</html>
