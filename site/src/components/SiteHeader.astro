---
const baseUrl = import.meta.env.BASE_URL || "/";
const withBase = (path) => `${baseUrl}${path.replace(/^\//, "")}`;
const navLinks = [
  { label: "Home", href: withBase("") },
  { label: "Features", href: withBase("features") },
  { label: "Downloads", href: withBase("downloads") },
  { label: "Docs", href: withBase("docs") },
  { label: "Wallpapers", href: withBase("wallpapers") },
  { label: "Community", href: withBase("community") }
];
---
<header class="nav">
  <div class="container nav-inner">
    <a class="nav-brand" href={withBase("")}>
      <img src={withBase("branding/bOS14.png")} alt="BoredOS logo" width="32" height="32" loading="lazy" />
      <span>BoredOS</span>
    </a>
    <nav class="nav-links">
      {navLinks.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </nav>
    <div>
      <a class="btn btn-primary" href={withBase("downloads")}>Get BoredOS</a>
    </div>
  </div>
</header>
