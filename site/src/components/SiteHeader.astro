---
import ThemeToggle from "./ThemeToggle.astro";

const baseUrl = import.meta.env.BASE_URL || "/";
const withBase = (path) => `${baseUrl}${path.replace(/^\//, "")}`;
const navLinks = [
  { label: "Home", href: withBase("") },
  { label: "Features", href: withBase("features") },
  { label: "Downloads", href: withBase("downloads") },
  { label: "Docs", href: withBase("docs") },
  { label: "Wallpapers", href: withBase("wallpapers") },
  { label: "Community", href: withBase("community") }
];
---
<header class="nav">
  <div class="container nav-inner">
    <a class="nav-brand" href={withBase("")}>
      <img src={withBase("branding/bOS14.png")} alt="BoredOS logo" width="32" height="32" loading="lazy" />
      <span>BoredOS</span>
    </a>
    
    <nav class="nav-desktop">
      {navLinks.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
      <ThemeToggle />
      <a class="btn btn-primary" href={withBase("downloads")}>Get BoredOS</a>
    </nav>

    <div style="display:flex; align-items:center; gap:8px;">
      <div class="nav-mobile-toggle" style="display:flex;">
        <ThemeToggle />
      </div>
      <button class="nav-toggle" aria-label="Toggle menu" id="navToggle">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</header>

<div class="nav-mobile" id="navMenu">
  <nav class="nav-mobile-links">
    {navLinks.map((link) => (
      <a href={link.href}>{link.label}</a>
    ))}
  </nav>
  <div class="nav-mobile-actions">
    <a class="btn btn-primary" href={withBase("downloads")}>Get BoredOS</a>
  </div>
</div>

<script>
  const navToggle = document.getElementById('navToggle');
  const navMenu = document.getElementById('navMenu');
  
  if (navToggle && navMenu) {
    navToggle.addEventListener('click', () => {
      const isExpanded = navToggle.getAttribute('aria-expanded') === 'true';
      navToggle.setAttribute('aria-expanded', !isExpanded);
      navToggle.classList.toggle('active');
      navMenu.classList.toggle('active');
      document.body.style.overflow = !isExpanded ? 'hidden' : '';
    });

    // Close menu when clicking a link
    navMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        navToggle.setAttribute('aria-expanded', 'false');
        navToggle.classList.remove('active');
        navMenu.classList.remove('active');
        document.body.style.overflow = '';
      });
    });
  }
</script>
