---
const { features = [], layout } = Astro.props;
const countClass = `feature-grid--count-${features.length}`;
const layoutClass = layout ? `feature-grid--${layout}` : "";
const className = ["feature-grid", countClass, layoutClass].filter(Boolean).join(" ");
---
<div class={className} data-reveal>
  {features.map((feature) => (
    <article class="feature-card">
      <h3>{feature.title}</h3>
      <p>{feature.description}</p>
    </article>
  ))}
</div>
