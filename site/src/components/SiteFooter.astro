---
const baseUrl = import.meta.env.BASE_URL || "/";
const withBase = (path) => `${baseUrl}${path.replace(/^\//, "")}`;

const links = [
  {
    title: "Explore",
    items: [
      { label: "Documentation", href: withBase("docs") },
      { label: "Features", href: withBase("features") },
      { label: "Downloads", href: withBase("downloads") }
    ]
  },
  {
    title: "Community",
    items: [
      { label: "GitHub", href: "https://github.com/boreddevnl/BoredOS" },
      { label: "Discord", href: "https://discord.gg/J2BxWaFAgY" },
      { label: "Support", href: "https://buymeacoffee.com/boreddevhq" }
    ]
  },
  {
    title: "Project",
    items: [
      { label: "Wallpapers", href: withBase("wallpapers") },
      { label: "AppDev SDK", href: withBase("docs/appdev/sdk_reference") }
    ]
  }
];
---
<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a class="nav-brand" href={withBase("")}>
        <img src={withBase("branding/bOS14.png")} alt="BoredOS logo" width="36" height="36" loading="lazy" />
        <span>BoredOS</span>
      </a>
      <p>A modern x86_64 hobbyist operating system built for developers, by developers.</p>
      <div class="footer-socials">
        <a href="https://github.com/boreddevnl/BoredOS" aria-label="GitHub">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
        </a>
        <a href="https://discord.gg/J2BxWaFAgY" aria-label="Discord">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M8 12h.01"></path><path d="M12 12h.01"></path><path d="M16 12h.01"></path></svg>
        </a>
      </div>
    </div>

    <div class="footer-nav">
      {links.map((group) => (
        <div class="footer-group">
          <strong>{group.title}</strong>
          <ul>
            {group.items.map((item) => (
              <li><a href={item.href}>{item.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <small>© 2023-2026 BoredDevNL. Licensed under GPL v3.</small>
      <div class="footer-meta">
        <span class="dot"></span>
        <a href="https://buymeacoffee.com/boreddevhq">Support the project</a>
      </div>
    </div>
  </div>
</footer>
