---
const { contributors = [] } = Astro.props;

const formatContribution = (contributor) => {
  if (typeof contributor.contributions === "number") {
    return `${contributor.contributions} contributions`;
  }

  if (contributor.contributionLabel) {
    return contributor.contributionLabel;
  }

  return "Contributor";
};
---
<div class="contributors-grid" data-reveal>
  {contributors.map((contributor) => (
    <a class="contributor-card" href={contributor.html_url}>
      <img src={contributor.avatar_url} alt={contributor.login} loading="lazy" />
      <strong>{contributor.login}</strong>
      <small>{formatContribution(contributor)}</small>
    </a>
  ))}
</div>
