---
const { title, description, primaryAction, secondaryAction, tertiaryAction } = Astro.props;
---
<section class="section">
  <div class="container">
    <div class="cta-card" data-reveal>
      <h2>{title}</h2>
      <p>{description}</p>
      <div style="display:flex; gap:12px; flex-wrap:wrap;">
        {primaryAction ? (
          <a class="btn btn-ghost" href={primaryAction.href}>{primaryAction.label}</a>
        ) : null}
        {secondaryAction ? (
          <a class="btn btn-ghost" href={secondaryAction.href}>{secondaryAction.label}</a>
        ) : null}
        {tertiaryAction ? (
          <a class="btn btn-ghost" href={tertiaryAction.href}>{tertiaryAction.label}</a>
        ) : null}
      </div>
    </div>
  </div>
</section>
