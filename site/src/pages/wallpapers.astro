---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";

const baseUrl = import.meta.env.BASE_URL || "/";
const withBase = (path) => `${baseUrl}${path.replace(/^\//, "")}`;

const wallpapers = [
  { src: withBase("branding/wallpapers/bored%20bird.png"), name: "Bored Bird" },
  { src: withBase("branding/wallpapers/boredos.png"), name: "BoredOS" },
  { src: withBase("branding/wallpapers/boredshadow.png"), name: "BoredShadow" }
];
---
<BaseLayout title="Wallpapers" description="Download official BoredOS wallpapers and art.">
  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Wallpapers"
        title="Official BoredOS artwork."
        description="High-resolution wallpapers drawn from the current desktop themes." />
<div class="screenshot-grid" data-reveal>
          {wallpapers.map((wallpaper) => (
            <div class="screenshot-item wallpaper-item">
              <a class="wallpaper-download" href={wallpaper.src} download>
                <img src={wallpaper.src} alt={wallpaper.name} loading="lazy" />
              </a>
              <a class="wallpaper-credit" href="https://github.com/naplon74" aria-label="Wallpaper artwork credit: Naplon74">
                <img src="https://avatars.githubusercontent.com/u/94738563?v=4" alt="" loading="lazy" />
                <span>@naplon74</span>
              </a>
            </div>
          ))}
        </div>
    </div>
  </section>
</BaseLayout>
