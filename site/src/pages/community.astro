---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ContributorsGrid from "../components/ContributorsGrid.astro";
import githubData from "../data/github-data.json";
import wallpapersData from "../data/wallpapers.json";

const wallpaperArtists = Array.from(
  wallpapersData.reduce((map, wallpaper) => {
    const credit = wallpaper.credit || {};
    const key = (credit.href || credit.label || "").toLowerCase();
    if (!key || map.has(key)) {
      return map;
    }

    map.set(key, {
      login: credit.label || "Wallpaper artist",
      avatar_url: credit.avatar || "",
      html_url: credit.href || "",
      contributionLabel: "Wallpaper artist"
    });

    return map;
  }, new Map())
  .values()
);

const contributorKeys = new Set(
  githubData.contributors.map((contributor) =>
    (contributor.html_url || contributor.login || "").toLowerCase()
  )
);

const communityContributors = [
  ...githubData.contributors,
  ...wallpaperArtists.filter(
    (artist) =>
      !contributorKeys.has((artist.html_url || artist.login || "").toLowerCase())
  )
];
---
<BaseLayout title="Community" description="Meet the contributors and join the BoredOS community.">
  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Community"
        title="Built by a community."
        description="Everyone who has contributed code or artwork to BoredOS." />
      <ContributorsGrid contributors={communityContributors} />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Get involved"
        title="Join the builders."
        description="Share ideas, build apps, and push the next release forward." />
      <div class="feature-grid feature-grid--count-3 feature-grid--cta" data-reveal>
        <article class="feature-card">
          <h3>GitHub</h3>
          <p>Report issues, explore the codebase, and open pull requests.</p>
          <a class="btn btn-ghost" href="https://github.com/boreddevnl/BoredOS">Visit GitHub</a>
        </article>
        <article class="feature-card">
          <h3>Support</h3>
          <p>Keep development moving by supporting the project financially.</p>
          <a class="btn btn-ghost" href="https://buymeacoffee.com/boreddevhq">Buy a coffee</a>
        </article>
        <article class="feature-card">
          <h3>Discord</h3>
          <p>Chat with the community and get real-time help from maintainers.</p>
          <a class="btn btn-ghost" href="https://discord.gg/J2BxWaFAgY">Join Discord</a>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
