---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import FeatureGrid from "../components/FeatureGrid.astro";
import ScreenshotGallery from "../components/ScreenshotGallery.astro";
import CallToAction from "../components/CallToAction.astro";

const features = [
  {
    title: "SMP-aware kernel",
    description: "Preemptive scheduling with per-CPU state, LAPIC/IPI coordination, and interrupt-safe locks."
  },
  {
    title: "Grapher 3D",
    description: "Interactive 2D/3D math plotting with 4-thread parallel rendering and Phong-style shading."
  },
  {
    title: "Native toolchain",
    description: "Build apps on the metal with the Tiny C Compiler (TCC), Lua, and a rich C SDK."
  },
  {
    title: "Lumos search",
    description: "Instant access to any file or app via the global fuzzy-search launch assistant."
  }
];

const screenshots = [
  { src: "/branding/screenshot.jpg", alt: "BoredOS desktop screenshot" },
  { src: "/branding/screenshot2.jpg", alt: "BoredOS desktop overview" },
  { src: "/branding/screenshot3.jpg", alt: "BoredOS UI details" }
];

const baseUrl = import.meta.env.BASE_URL || "/";
const withBase = (path) => `${baseUrl}${path.replace(/^\//, "")}`;
---
<BaseLayout>
  <Hero
    title="For developers, by developers."
    description="BoredOS is an x86_64 operating system for developers. It's FOSS, licensed under GPLv3 and has a large amount of documentation."
    image="/branding/wallpapers/boredos.png"
    imageAlt="BoredOS wallpaper"
    primaryAction={{ label: "Download", href: withBase("downloads") }}
    secondaryAction={{ label: "Read the docs", href: withBase("docs") }}
  />

  <section class="section">
    <div class="container glass" style="padding: clamp(32px, 5vw, 64px); border-radius: var(--radius-lg);">
      <SectionHeading
        eyebrow="Why BoredOS"
        title="Built for depth, designed for power."
        description="From a multi-core SMP kernel to professional-grade math tools and a native C compiler, BoredOS is a developer's playground."
      />
      <FeatureGrid features={features} layout="balanced-4" />
      <div class="section-cta">
        <a class="btn btn-primary" href={withBase("features")}>See all features</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Screens"
        title="A usable desktop, built from scratch."
        description="BoredWM provides a familiar stacking interface with grid-snapping icons and a fuzzy file search (Lumos)." />
      <ScreenshotGallery items={screenshots} layout="carousel" />
    </div>
  </section>

  <CallToAction
    title="Build on an OS written by developers."
    description="Ship ELF apps with the SDK, poke the kernel, and join builders pushing BoredOS forward."
    primaryAction={{ label: "Explore docs", href: withBase("docs") }}
    secondaryAction={{ label: "Join Discord", href: "https://discord.gg/J2BxWaFAgY" }}
    tertiaryAction={{ label: "GitHub", href: "https://github.com/boreddevnl/BoredOS" }}
  />
</BaseLayout>
